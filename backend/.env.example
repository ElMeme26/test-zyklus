# Zyklus Halo — Variables de entorno del Backend
# Copiar este archivo a .env y completar los valores

# Puerto del servidor (default: 3000)
PORT=3000

# Origen CORS permitido (URL del frontend)
# Desarrollo: http://localhost:5173
# Producción: https://tudominio.netlify.app
FRONTEND_ORIGIN=http://localhost:5173

# Cadena de conexión PostgreSQL (OBLIGATORIO)
# Ejemplo Supabase: postgresql://postgres.[proyecto]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://user:password@host:5432/database

# Secreto para firmar JWT (OBLIGATORIO en producción)
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=dev-secret-change-in-production
