# Zyklus Halo — Variables de entorno del Frontend
# Copiar este archivo a .env y completar los valores

# URL base del backend (API REST)
# Desarrollo: http://localhost:3000
# Producción: https://api.tudominio.com
VITE_API_URL=http://localhost:3000

# API Key de Google Gemini (opcional, para ChatAssistant)
# Obtener en: https://makersuite.google.com/app/apikey
# VITE_GEMINI_API_KEY=AIza...
